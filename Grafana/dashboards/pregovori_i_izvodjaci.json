      },
      "id": 3,
      "options": {
        "displayLabels": [
          "percent",
          "name"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "pie",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^cnt$/",
          "values": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "cypherQuery": "MATCH (p:Performer)-[:PART_OF]->(n:Negotiation)-[:IN_STATE]->(s:State)\r\nWITH p.genre AS genre, count(n) AS cnt\r\nRETURN genre, cnt\r\nORDER BY cnt DESC",
          "datasource": {
            "type": "kniepdennis-neo4j-datasource",
            "uid": "neo4j-performer"
          },
          "query": "MATCH (p:Performer)-[:PART_OF]->(n:Negotiation)-[:IN_STATE]->(s:State) WHERE s.isFinal = true RETURN p.genre AS genre, count(n) AS broj_pregovora ORDER BY broj_pregovora DESC",
          "rawQuery": "MATCH (p:Performer)-[:PART_OF]->(n:Negotiation)-[:IN_STATE]->(s:State) WHERE s.isFinal = true RETURN p.genre AS genre, count(n) AS broj_pregovora ORDER BY broj_pregovora DESC",
          "refId": "A"
        }
      ],
      "title": "Broj pregovora po žanru izvođača",
      "type": "piechart"
