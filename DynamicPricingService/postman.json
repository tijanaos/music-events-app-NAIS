        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/ticket-types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ticket-types"]
            }
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/ticket-types/{{ticketTypeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ticket-types", "{{ticketTypeId}}"]
            }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Pass\",\n  \"maxAvailable\": 3000,\n  \"soldCount\": 0,\n  \"schedules\": [\n    {\n      \"periodStart\": \"2026-04-16\",\n      \"periodEnd\": \"2026-05-31\",\n      \"basePrice\": 2500.0,\n      \"currentPrice\": 2500.0,\n      \"minPrice\": 1500.0,\n      \"expectedSales\": 2,\n      \"soldInPeriod\": 0,\n      \"priceStep\": 100.0\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/ticket-types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "ticket-types"]
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Pass\",\n  \"maxAvailable\": 3000,\n  \"soldCount\": 5,\n  \"schedules\": [\n    {\n      \"periodStart\": \"2026-04-16\",\n      \"periodEnd\": \"2026-05-31\",\n      \"basePrice\": 2500.0,\n      \"currentPrice\": 2600.0,\n      \"minPrice\": 1500.0,\n      \"expectedSales\": 2,\n      \"soldInPeriod\": 5,\n      \"priceStep\": 100.0\n    }\n  ]\n}"
